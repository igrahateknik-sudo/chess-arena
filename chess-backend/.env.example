# ── Server ────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES=12h

# ── Supabase ──────────────────────────────────────────────────
# Get from: https://supabase.com → Your Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ── Midtrans ──────────────────────────────────────────────────
# Get from: https://dashboard.midtrans.com → Settings → Access Keys
# Use sandbox keys for development, production keys for live
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx

# ── Frontend ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# ── Redis (optional — enables Socket.IO horizontal scaling) ───
# Leave empty to run in single-instance mode (default for Railway Starter plan)
# Add a Redis service in Railway, then set this to its connection string
# Format: redis://default:<password>@<host>:<port>
# REDIS_URL=redis://default:password@containers-us-west-123.railway.app:6379

# ── Admin security (optional but recommended) ────────────────
# Step-up secret required for admin mutation endpoints (POST/PUT/PATCH/DELETE)
# when configured. Send via header: x-admin-stepup: <ADMIN_STEPUP_SECRET>
# ADMIN_STEPUP_SECRET=change-this-long-random-secret
